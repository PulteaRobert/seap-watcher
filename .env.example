# WhatsApp: recipient phone number(s) in E.164 format (e.g., 40712345678).
# For multiple recipients, use a comma-separated list, e.g.:
# WHATSAPP_TO_PHONE=40712345678,40798765432
WHATSAPP_TO_PHONE=40XXXXXXXXXX

# SEAP: Brasov county name (case-insensitive)
SEAP_COUNTY=Brasov

# Schedule: cron expressions (Europe/Bucharest timezone)
CRON_MORNING=0 7 * * 1-5
CRON_AFTERNOON=0 13 * * 1-5

# SQLite database path
DB_PATH=./data/seap-watcher.db

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Max tenders per run (SEAP API limit safeguard)
MAX_TENDERS_PER_RUN=200

# Development: set to 1 to skip live WhatsApp (logs messages instead)
# NO_OP_WHATSAPP=1
